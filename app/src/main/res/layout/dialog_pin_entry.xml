<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="@drawable/bg_pin_dialog_card">

    <!-- Cast / Pairing Icon Header -->
    <ImageView
        android:id="@+id/dialogIcon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_cast"
        android:layout_marginBottom="16dp"
        app:tint="@color/kg_accent" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/dialog_pin_title"
        android:textColor="@color/kg_text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:gravity="center" />

    <!-- Message / Subtitle -->
    <TextView
        android:id="@+id/dialogPinMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/dialog_pin_message"
        android:textColor="@color/kg_text_secondary"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- Visual 4-Digit Row -->
    <LinearLayout
        android:id="@+id/pinRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="28dp"
        android:focusable="true"
        android:clickable="true">

        <TextView
            android:id="@+id/pinDigit1"
            android:layout_width="56dp"
            android:layout_height="64dp"
            android:gravity="center"
            android:textSize="28sp"
            android:textColor="@color/kg_text_primary"
            android:textStyle="bold"
            android:background="@drawable/bg_pin_digit"
            android:layout_marginEnd="10dp" />

        <TextView
            android:id="@+id/pinDigit2"
            android:layout_width="56dp"
            android:layout_height="64dp"
            android:gravity="center"
            android:textSize="28sp"
            android:textColor="@color/kg_text_primary"
            android:textStyle="bold"
            android:background="@drawable/bg_pin_digit"
            android:layout_marginEnd="10dp" />

        <TextView
            android:id="@+id/pinDigit3"
            android:layout_width="56dp"
            android:layout_height="64dp"
            android:gravity="center"
            android:textSize="28sp"
            android:textColor="@color/kg_text_primary"
            android:textStyle="bold"
            android:background="@drawable/bg_pin_digit"
            android:layout_marginEnd="10dp" />

        <TextView
            android:id="@+id/pinDigit4"
            android:layout_width="56dp"
            android:layout_height="64dp"
            android:gravity="center"
            android:textSize="28sp"
            android:textColor="@color/kg_text_primary"
            android:textStyle="bold"
            android:background="@drawable/bg_pin_digit" />

    </LinearLayout>

    <!-- Hidden EditText to capture input -->
    <EditText
        android:id="@+id/hiddenPinInput"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:background="@android:color/transparent"
        android:textColor="@android:color/transparent"
        android:cursorVisible="false"
        android:inputType="number"
        android:maxLength="4"
        android:imeOptions="actionDone"
        android:importantForAutofill="no" />

    <!-- Material Design Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/Widget.Mirror.Button.Outlined"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_cancel"
            android:layout_marginEnd="12dp"
            android:minWidth="100dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConnect"
            style="@style/Widget.Mirror.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_connect"
            android:minWidth="100dp" />

    </LinearLayout>

</LinearLayout>
